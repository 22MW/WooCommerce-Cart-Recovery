msgid "Cart Recovery"
msgstr "Warenkorbwiederherstellung"

msgid "Carts"
msgstr "Warenkörbe"

msgid "Settings"
msgstr "Einstellungen"

msgid "{customer_name}, you left something in your cart"
msgstr "{customer_name}, du hast etwas in deinem Warenkorb gelassen"

msgid "Hi {customer_name}, your cart is still available. Click the button below to complete your order: {recovery_link}"
msgstr "Hallo {customer_name}, dein Warenkorb ist noch verfügbar. Klicke auf die Schaltfläche unten, um deine Bestellung abzuschließen: {recovery_link}"

msgid "{customer_name}, your cart is waiting for you"
msgstr "{customer_name}, dein Warenkorb wartet auf dich"

msgid "Hi {customer_name}, complete your purchase here: {recovery_link}. Discount: {coupon_label}. Code: {coupon_code}"
msgstr "Hallo {customer_name}, schließe hier deinen Kauf ab: {recovery_link}. Rabatt: {coupon_label}. Code: {coupon_code}"

msgid "{customer_name}, last reminder for your cart"
msgstr "{customer_name}, letzte Erinnerung an deinen Warenkorb"

msgid "Hi {customer_name}, your cart can still be recovered here: {recovery_link}. Discount: {coupon_label}. Code: {coupon_code}"
msgstr "Hallo {customer_name}, du kannst deinen Warenkorb hier noch wiederherstellen: {recovery_link}. Rabatt: {coupon_label}. Code: {coupon_code}"

#. translators: %s: customer name
msgid "Hello %s,"
msgstr "Hallo %s,"

#. translators: %s: discount label
msgid "Complete your order with %s."
msgstr "Schließe deine Bestellung mit %s ab."

msgid "Your cart summary"
msgstr "Zusammenfassung deines Warenkorbs"

msgid "Product"
msgstr "Produkt"

msgid "Quantity"
msgstr "Menge"

msgid "Price"
msgstr "Preis"

msgid "Total"
msgstr "Gesamt"

msgid "Discount code"
msgstr "Rabattcode"

msgid "Recover your cart"
msgstr "Warenkorb wiederherstellen"

#. translators: %s: discount label
msgid "%s off"
msgstr "%s Rabatt"
