#: includes/repositories/class-settings-repository.php:268
msgid "{customer_name}, you left something in your cart"
msgstr "{customer_name}, du hast etwas in deinem Warenkorb gelassen"

#: includes/repositories/class-settings-repository.php:269
msgid "Hi {customer_name}, you left some items in your cart at {site_name}. We saved everything for you — just click the button below to complete your order in a few clicks."
msgstr "Hallo {customer_name}, du hast einige Artikel in deinem Warenkorb bei {site_name} gelassen. Wir haben alles gespeichert — klicke auf die Schaltfläche unten, um deine Bestellung in wenigen Schritten abzuschließen."

#: includes/repositories/class-settings-repository.php:277
msgid "{customer_name}, your cart is waiting for you"
msgstr "{customer_name}, dein Warenkorb wartet auf dich"

#: includes/repositories/class-settings-repository.php:278
msgid "Hi {customer_name}, your cart at {site_name} is still waiting. Everything you selected is still available — come back and complete your order before it is gone."
msgstr "Hallo {customer_name}, dein Warenkorb bei {site_name} wartet noch auf dich. Alles, was du ausgewählt hast, ist noch verfügbar — komm zurück und schließe deine Bestellung ab, bevor es weg ist."

#: includes/repositories/class-settings-repository.php:286
msgid "{customer_name}, last reminder for your cart"
msgstr "{customer_name}, letzte Erinnerung an deinen Warenkorb"

#: includes/repositories/class-settings-repository.php:287
msgid "Hi {customer_name}, this is your last reminder. Your cart at {site_name} is about to expire. Don't miss out — complete your order today."
msgstr "Hallo {customer_name}, dies ist deine letzte Erinnerung. Dein Warenkorb bei {site_name} läuft bald ab. Verpasse es nicht — schließe deine Bestellung noch heute ab."

